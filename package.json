{
  "name": "@or-abdillh/pinia-persisted-indexeddb",
  "version": "1.0.0",
  "description": "Pinia plugin for persisted state using IndexedDB with automatic fallback chain (IndexedDB → localStorage → sessionStorage → memory)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "pinia",
    "vue",
    "vue3",
    "indexeddb",
    "persist",
    "persistence",
    "storage",
    "offline",
    "state-management"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/or-abdillh/pinia-persisted-indexeddb.git"
  },
  "bugs": {
    "url": "https://github.com/or-abdillh/pinia-persisted-indexeddb/issues"
  },
  "homepage": "https://github.com/or-abdillh/pinia-persisted-indexeddb#readme",
  "peerDependencies": {
    "pinia": ">=2.0.0",
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.0.0",
    "@vue/tsconfig": "^0.9.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "npm-run-all2": "^8.0.4",
    "pinia": "^3.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
